{
  "name": "@mik1810/nxpp-wasm",
  "version": "0.6.0",
  "description": "Experimental Node.js WASM bindings for nxpp",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": "./nxpp.mjs"
  },
  "files": [
    "dist/",
    "ts/",
    "tsconfig.json",
    "nxpp.mjs",
    "build/nxpp_node.mjs",
    "build/nxpp_node.wasm",
    "README.md"
  ],
  "keywords": [
    "graph",
    "wasm",
    "emscripten",
    "nxpp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "check:node-contract": "bash scripts/run_wasm_node_contract_tests.sh",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org/",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com/",
    "publish:all": "npm run publish:npm && npm run publish:github"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mik1810/nxpp.git"
  },
  "homepage": "https://github.com/Mik1810/nxpp",
  "bugs": {
    "url": "https://github.com/Mik1810/nxpp/issues"
  }
}
