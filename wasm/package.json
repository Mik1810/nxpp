{
  "name": "@mik1810/nxpp-wasm",
  "version": "0.1.2",
  "description": "Experimental Node.js WASM bindings for nxpp",
  "type": "module",
  "main": "./nxpp.mjs",
  "exports": "./nxpp.mjs",
  "files": [
    "nxpp.mjs",
    "build/nxpp_node.mjs",
    "build/nxpp_node.wasm",
    "README.md"
  ],
  "keywords": [
    "graph",
    "wasm",
    "emscripten",
    "nxpp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "publish:npm": "npm publish --registry=https://registry.npmjs.org",
    "publish:github": "npm publish --ignore-scripts --registry=https://npm.pkg.github.com",
    "publish:all": "npm run publish:npm",
    "postpublish": "npm run publish:github"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mik1810/nxpp.git"
  },
  "homepage": "https://github.com/Mik1810/nxpp",
  "bugs": {
    "url": "https://github.com/Mik1810/nxpp/issues"
  }
}
