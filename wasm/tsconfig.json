{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "ts",
    "outDir": "dist",
    "verbatimModuleSyntax": true
  },
  "include": ["ts/**/*.ts", "ts/**/*.d.ts"]
}
